{
  "name": "ai-agent-observer",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/dashboard",
    "build": "npm run build -w packages/shared && npm run build -w packages/sdk && npm run build -w packages/mcp && npm run build -w packages/ingestion && npm run build -w packages/dashboard",
    "mcp": "tsx packages/mcp/src/index.ts",
    "ingest": "tsx packages/ingestion/src/index.ts",
    "services": "docker compose up -d",
    "services:down": "docker compose down",
    "test:trace": "tsx test/send-trace.ts",
    "db:migrate": "prisma migrate dev --schema packages/shared/src/prisma/schema.prisma",
    "db:generate": "prisma generate --schema packages/shared/src/prisma/schema.prisma",
    "db:seed": "tsx packages/shared/src/seed.ts"
  }
}
